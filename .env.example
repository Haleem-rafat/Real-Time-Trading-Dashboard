# ============================================
# Real-Time Trading Dashboard — Environment
# ============================================
# Copy to .env and adjust values for your setup.

# ---- Backend ----
NODE_ENV=development
PORT=8080

# MongoDB
MONGODB_URL=mongodb://root:example@mongo:27017/trading?authSource=admin
MONGODB_DB_NAME=trading

# Redis
REDIS_URL=redis://redis:6379

# JWT (mock auth)
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_EXPIRES=24h

# CORS / Frontend
FRONTEND_URL=http://localhost:5173

# WebSocket
ALLOW_ANON_WS=true

# Market simulator
TICK_INTERVAL_MS=1000

# ---- Frontend (build args) ----
VITE_API_URL=http://localhost:8080/api/v1
VITE_SOCKET_URL=http://localhost:8080
